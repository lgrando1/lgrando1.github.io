&lt;h2&gt;Forms tests - Datas types&lt;/h2&gt;
  &lt;form name = &#34;form1&#34; method=&#34;post&#34; action=&#34;&#34;&gt;
    Field 1: &lt;input type=&#34;text&#34; name=&#34;autofocus here&#34;/&gt; &lt;br/&gt;
    Field 2: &lt;input type=&#34;email&#34; name=&#34;usermail&#34;/&gt; &lt;br/&gt;
    Field 3: &lt;input type=&#34;url&#34; name=&#34;homepage&#34;/&gt; &lt;br/&gt;
    Field 4:&lt;br/&gt;
        &lt;textarea rows=&#34;4&#34; cols=&#34;40&#34; required=&#34;required&#34;&gt;&lt;/textarea&gt;&lt;br/&gt;
  &lt;/form&gt;
&lt;h2&gt;Forms 2 - Checkbox &amp; Radio Butons&lt;/h2&gt;
&lt;form name = &#34;form2&#34; method=&#34;post&#34; action=&#34;&#34;&gt;
  &lt;input type=&#34;hidden&#34; name=&#34;oculto&#34; value=&#34;algumacoisa&#34; /&gt; 
&lt;p&gt;Choose a number &lt;br/&gt;
&lt;input type=&#34;checkbox&#34; name=&#34;number&#34; value=&#34;one&#34; /&gt;one &lt;br/&gt;
&lt;input type=&#34;checkbox&#34; name=&#34;number&#34; value=&#34;two&#34; /&gt;two &lt;br/&gt;
&lt;br/&gt;
&lt;input type=&#34;button&#34; name=&#34;botao&#34; value=&#34;Click here&#34; onclick=&#34;alert(&#39;Hello&#39;)&#34;/&gt;&lt;/p&gt;
  &lt;br/&gt;
&lt;p&gt;Choose a value: &lt;br/&gt;
&lt;input type=&#34;radio&#34; name=&#34;value 1&#34; value=&#34;1&#34; /&gt;Value 1 &lt;br/&gt;
&lt;input type=&#34;radio&#34; name=&#34;value 2&#34; value=&#34;2&#34; /&gt;Value 2 &lt;br/&gt;
&lt;br/&gt;&lt;/p&gt;
&lt;p&gt;Option List:&lt;br/&gt;
&lt;input list = &#34;Some birds names&#34; name=&#34;Calopsitas&#34; /&gt;
&lt;datalist id=&#34;Calopsita&#34;&gt;
&lt;option value=&#34;Juquinha&#34;&gt;
